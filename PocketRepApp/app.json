{
  "expo": {
    "name": "PocketRep",
    "slug": "pocketrep",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "pocketrep",
    "splash": {
      "backgroundColor": "#0c0c0e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pro.pocketrep.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0c0c0e"
      },
      "package": "pro.pocketrep.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        { "microphonePermission": "PocketRep needs mic access for Voice-to-Rex." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "PocketRep needs photo access for Rapport Vault." }
      ],
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "PocketRep uses location for proximity alerts." }
      ],
      [
        "expo-notifications",
        { "icon": "./assets/icon.png" }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "single-page",
      "favicon": "./assets/icon.png"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
